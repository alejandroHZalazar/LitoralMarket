@page
@model LitoralMarket.Web.Pages.Admin.DireccionesEntrega.IndexModel
@{
    ViewData["Title"] = "Direcciones de Entrega";
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <h2 class="mb-0"><i class="bi bi-geo-alt me-2 text-success"></i>Direcciones de Entrega</h2>
    <button class="btn btn-success" id="btnNuevo">
        <i class="bi bi-plus-lg me-1"></i>Nueva dirección
    </button>
</div>

<!-- ===== TABLA ===== -->
<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <table class="table table-sm table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th style="width:64px" class="text-center">Orden</th>
                    <th>Descripción</th>
                    <th>Tipo</th>
                    <th>Localidad</th>
                    <th class="text-end">Costo</th>
                    <th class="text-center">Estado</th>
                    <th class="text-center">Default</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var d in Model.Direcciones)
                {
                    var tipoBadge = d.TipoEntrega switch
                    {
                        "domicilio" => "<span class=\"badge bg-primary\">Domicilio</span>",
                        "fijo"      => "<span class=\"badge bg-info text-dark\">Punto fijo</span>",
                        _           => "<span class=\"badge bg-secondary\">Retiro</span>"
                    };
                    var costoLabel = d.EsGratis || d.CostoEnvio == 0
                        ? "<span class=\"text-success fw-semibold\">Gratis</span>"
                        : $"<span>${d.CostoEnvio:N2}</span>";

                    <tr class="@(!d.Activo ? "table-secondary text-muted" : "")">
                        <td class="text-center">
                            <div class="d-flex flex-column align-items-center">
                                <button class="btn btn-link btn-sm p-0 lh-1 btn-mover"
                                        data-id="@d.Id" data-subir="true" title="Subir">
                                    <i class="bi bi-chevron-up"></i>
                                </button>
                                <small class="text-muted">@d.Orden</small>
                                <button class="btn btn-link btn-sm p-0 lh-1 btn-mover"
                                        data-id="@d.Id" data-subir="false" title="Bajar">
                                    <i class="bi bi-chevron-down"></i>
                                </button>
                            </div>
                        </td>
                        <td>
                            <span class="fw-semibold">@d.Descripcion</span>
                            @if (d.PermiteLibre)
                            {
                                <span class="badge bg-light text-secondary ms-1" title="Permite dirección libre">
                                    <i class="bi bi-pencil-square"></i>
                                </span>
                            }
                            @if (!string.IsNullOrEmpty(d.Referencia))
                            {
                                <div class="text-muted small">@d.Referencia</div>
                            }
                        </td>
                        <td>@Html.Raw(tipoBadge)</td>
                        <td class="small text-muted">
                            @if (!string.IsNullOrEmpty(d.Localidad))
                            {
                                @d.Localidad
                                if (!string.IsNullOrEmpty(d.Provincia)) { <text>, @d.Provincia</text> }
                            }
                            else { <text>—</text> }
                        </td>
                        <td class="text-end">@Html.Raw(costoLabel)</td>
                        <td class="text-center">
                            @if (d.Activo)
                            {
                                <span class="badge bg-success">Activa</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Inactiva</span>
                            }
                        </td>
                        <td class="text-center">
                            @if (d.EsDefault)
                            {
                                <i class="bi bi-star-fill text-warning" title="Dirección por defecto"></i>
                            }
                        </td>
                        <td class="text-end text-nowrap">
                            <button class="btn btn-sm btn-outline-primary me-1 btn-editar"
                                    data-id="@d.Id" title="Editar">
                                <i class="bi bi-pencil"></i>
                            </button>
                            <button class="btn btn-sm @(d.Activo ? "btn-outline-warning" : "btn-outline-success") me-1 btn-toggle"
                                    data-id="@d.Id" title="@(d.Activo ? "Desactivar" : "Activar")">
                                <i class="bi bi-@(d.Activo ? "eye-slash" : "eye")"></i>
                            </button>
                            <button class="btn btn-sm btn-outline-danger btn-eliminar"
                                    data-id="@d.Id" data-nombre="@d.Descripcion" title="Eliminar">
                                <i class="bi bi-trash"></i>
                            </button>
                        </td>
                    </tr>
                }
                @if (!Model.Direcciones.Any())
                {
                    <tr><td colspan="8" class="text-center text-muted py-4">
                        <i class="bi bi-geo-alt me-1"></i>No hay direcciones configuradas. Creá una con el botón "Nueva dirección".
                    </td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- =========================================================
     MODAL ABM
     ========================================================= -->
<div class="modal fade" id="direccionModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header border-bottom">
                <h5 class="modal-title fw-bold" id="modalTitulo">
                    <i class="bi bi-geo-alt me-2 text-success"></i>Dirección de entrega
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <div id="alertaModal" class="alert alert-danger d-none py-2 small mb-3"></div>
                <div class="row g-3">

                    <!-- Col izquierda -->
                    <div class="col-12 col-md-6">
                        <div class="admin-section-title">Identificación</div>

                        <div class="mb-2">
                            <label class="form-label form-label-sm">Descripción *</label>
                            <input type="text" id="fDescripcion" class="form-control form-control-sm"
                                   placeholder="Ej: Envío a domicilio" maxlength="200" />
                        </div>
                        <div class="mb-2">
                            <label class="form-label form-label-sm">Tipo de entrega</label>
                            <select id="fTipo" class="form-select form-select-sm">
                                <option value="retiro">Retiro en local</option>
                                <option value="domicilio">Envío a domicilio</option>
                                <option value="fijo">Punto fijo de entrega</option>
                            </select>
                        </div>
                        <div class="mb-2" id="wrapDireccion">
                            <label class="form-label form-label-sm">Dirección</label>
                            <input type="text" id="fDireccion" class="form-control form-control-sm"
                                   placeholder="Calle, número..." />
                        </div>
                        <div class="row g-2 mb-2">
                            <div class="col-7">
                                <label class="form-label form-label-sm">Localidad</label>
                                <input type="text" id="fLocalidad" class="form-control form-control-sm" />
                            </div>
                            <div class="col-5">
                                <label class="form-label form-label-sm">Provincia</label>
                                <input type="text" id="fProvincia" class="form-control form-control-sm" />
                            </div>
                        </div>
                        <div class="mb-2">
                            <label class="form-label form-label-sm">Referencia / Indicaciones</label>
                            <input type="text" id="fReferencia" class="form-control form-control-sm"
                                   placeholder="Ej: Horario de retiro 9-18hs" />
                        </div>
                    </div>

                    <!-- Col derecha -->
                    <div class="col-12 col-md-6">
                        <div class="admin-section-title">Costo y opciones</div>

                        <div class="form-check form-switch mb-2">
                            <input type="checkbox" id="fEsGratis" class="form-check-input" />
                            <label class="form-check-label" for="fEsGratis">Envío gratuito</label>
                        </div>
                        <div id="wrapCosto" class="mb-3">
                            <label class="form-label form-label-sm">Costo de envío</label>
                            <div class="input-group input-group-sm">
                                <span class="input-group-text">$</span>
                                <input type="number" id="fCostoEnvio" class="form-control" step="0.01" min="0" value="0" />
                            </div>
                        </div>

                        <div class="admin-section-title mt-3">Comportamiento</div>

                        <div class="form-check form-switch mb-2">
                            <input type="checkbox" id="fPermiteLibre" class="form-check-input" />
                            <label class="form-check-label" for="fPermiteLibre">
                                Permite ingresar dirección libre
                                <small class="text-muted d-block">El cliente puede escribir su propia dirección.</small>
                            </label>
                        </div>
                        <div class="form-check form-switch mb-2">
                            <input type="checkbox" id="fEsDefault" class="form-check-input" />
                            <label class="form-check-label" for="fEsDefault">
                                Dirección por defecto
                                <small class="text-muted d-block">Se pre-selecciona en el checkout.</small>
                            </label>
                        </div>
                        <div class="form-check form-switch mb-2">
                            <input type="checkbox" id="fActivo" class="form-check-input" checked />
                            <label class="form-check-label" for="fActivo">
                                Activa
                                <small class="text-muted d-block">Solo las activas aparecen en el checkout.</small>
                            </label>
                        </div>
                    </div>
                </div>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-success" id="btnGuardar">
                    <i class="bi bi-check-lg me-1"></i>Guardar
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Modal confirmar eliminación -->
<div class="modal fade" id="modalEliminar" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header border-0 bg-danger text-white">
                <h6 class="modal-title"><i class="bi bi-exclamation-triangle me-2"></i>Eliminar dirección</h6>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>¿Eliminar <strong id="nomDirElim"></strong>?</p>
                <p class="text-muted small mb-0">Esta acción es permanente.</p>
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-danger" id="btnEjecutarElim">
                    <i class="bi bi-trash me-1"></i>Eliminar
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
@Html.AntiForgeryToken()
<style>
    .admin-section-title {
        font-size:.68rem;font-weight:700;letter-spacing:1px;text-transform:uppercase;
        color:var(--verde-oscuro);border-bottom:2px solid rgba(29,176,98,.15);
        padding-bottom:3px;margin-bottom:8px;
    }
</style>
<script>
const TOKEN  = document.querySelector('input[name="__RequestVerificationToken"]').value;
let _idActual = 0;
let _idElim   = 0;

// ── helpers POST ─────────────────────────────────────────────────
async function post(handler, campos) {
    const fd = new FormData();
    fd.append('__RequestVerificationToken', TOKEN);
    Object.entries(campos).forEach(([k, v]) => fd.append(k, v));
    return fetch(`?handler=${handler}`, { method: 'POST', body: fd });
}

// ── Modal nuevo ───────────────────────────────────────────────────
document.getElementById('btnNuevo').addEventListener('click', () => {
    _idActual = 0;
    limpiarModal();
    document.getElementById('modalTitulo').innerHTML =
        '<i class="bi bi-plus-circle me-2 text-success"></i>Nueva dirección';
    new bootstrap.Modal(document.getElementById('direccionModal')).show();
});

// ── Modal editar ──────────────────────────────────────────────────
document.addEventListener('click', async e => {
    const btn = e.target.closest('.btn-editar');
    if (!btn) return;
    const id  = btn.dataset.id;
    const res = await fetch(`?handler=DireccionJson&id=${id}`);
    if (!res.ok) { alert('No se pudo cargar la dirección.'); return; }
    const d = await res.json();

    _idActual = d.id;
    document.getElementById('fDescripcion').value  = d.descripcion  ?? '';
    document.getElementById('fTipo').value         = d.tipoEntrega  ?? 'retiro';
    document.getElementById('fDireccion').value    = d.direccion    ?? '';
    document.getElementById('fLocalidad').value    = d.localidad    ?? '';
    document.getElementById('fProvincia').value    = d.provincia    ?? '';
    document.getElementById('fReferencia').value   = d.referencia   ?? '';
    document.getElementById('fCostoEnvio').value   = d.costoEnvio   ?? 0;
    document.getElementById('fEsGratis').checked   = d.esGratis;
    document.getElementById('fPermiteLibre').checked = d.permiteLibre;
    document.getElementById('fEsDefault').checked  = d.esDefault;
    document.getElementById('fActivo').checked     = d.activo;

    document.getElementById('alertaModal').classList.add('d-none');
    document.getElementById('modalTitulo').innerHTML =
        `<i class="bi bi-pencil me-2 text-success"></i>Editar: ${d.descripcion}`;

    actualizarVisibilidad();
    new bootstrap.Modal(document.getElementById('direccionModal')).show();
});

function limpiarModal() {
    document.getElementById('fDescripcion').value    = '';
    document.getElementById('fTipo').value           = 'retiro';
    document.getElementById('fDireccion').value      = '';
    document.getElementById('fLocalidad').value      = '';
    document.getElementById('fProvincia').value      = '';
    document.getElementById('fReferencia').value     = '';
    document.getElementById('fCostoEnvio').value     = '0';
    document.getElementById('fEsGratis').checked     = false;
    document.getElementById('fPermiteLibre').checked = false;
    document.getElementById('fEsDefault').checked    = false;
    document.getElementById('fActivo').checked       = true;
    document.getElementById('alertaModal').classList.add('d-none');
    actualizarVisibilidad();
}

function actualizarVisibilidad() {
    const tipo   = document.getElementById('fTipo').value;
    const gratis = document.getElementById('fEsGratis').checked;
    document.getElementById('wrapDireccion').style.display = tipo === 'retiro' ? 'none' : '';
    document.getElementById('wrapCosto').style.display     = gratis ? 'none' : '';
}

document.getElementById('fTipo').addEventListener('change',    actualizarVisibilidad);
document.getElementById('fEsGratis').addEventListener('change', actualizarVisibilidad);

// ── Guardar ───────────────────────────────────────────────────────
document.getElementById('btnGuardar').addEventListener('click', async () => {
    const desc = document.getElementById('fDescripcion').value.trim();
    const alerta = document.getElementById('alertaModal');
    if (!desc) {
        alerta.textContent = 'La descripción es obligatoria.';
        alerta.classList.remove('d-none');
        return;
    }
    alerta.classList.add('d-none');

    const res = await post('Guardar', {
        'Direccion.Id'          : _idActual,
        'Direccion.Descripcion' : desc,
        'Direccion.TipoEntrega' : document.getElementById('fTipo').value,
        'Direccion.Direccion_'  : document.getElementById('fDireccion').value,
        'Direccion.Localidad'   : document.getElementById('fLocalidad').value,
        'Direccion.Provincia'   : document.getElementById('fProvincia').value,
        'Direccion.Referencia'  : document.getElementById('fReferencia').value,
        'Direccion.CostoEnvio'  : document.getElementById('fCostoEnvio').value,
        'Direccion.EsGratis'    : document.getElementById('fEsGratis').checked,
        'Direccion.PermiteLibre': document.getElementById('fPermiteLibre').checked,
        'Direccion.EsDefault'   : document.getElementById('fEsDefault').checked,
        'Direccion.Activo'      : document.getElementById('fActivo').checked,
    });
    const data = await res.json();
    if (data.ok) {
        bootstrap.Modal.getInstance(document.getElementById('direccionModal')).hide();
        location.reload();
    } else {
        alerta.textContent = data.error ?? 'Error al guardar.';
        alerta.classList.remove('d-none');
    }
});

// ── Toggle activo ─────────────────────────────────────────────────
document.addEventListener('click', async e => {
    const btn = e.target.closest('.btn-toggle');
    if (!btn) return;
    await post('ToggleActivo', { id: btn.dataset.id });
    location.reload();
});

// ── Eliminar ──────────────────────────────────────────────────────
document.addEventListener('click', e => {
    const btn = e.target.closest('.btn-eliminar');
    if (!btn) return;
    _idElim = btn.dataset.id;
    document.getElementById('nomDirElim').textContent = btn.dataset.nombre;
    new bootstrap.Modal(document.getElementById('modalEliminar')).show();
});

document.getElementById('btnEjecutarElim').addEventListener('click', async () => {
    await post('Eliminar', { id: _idElim });
    bootstrap.Modal.getInstance(document.getElementById('modalEliminar')).hide();
    location.reload();
});

// ── Reordenar ─────────────────────────────────────────────────────
document.addEventListener('click', async e => {
    const btn = e.target.closest('.btn-mover');
    if (!btn) return;
    await post('Mover', { id: btn.dataset.id, subir: btn.dataset.subir });
    location.reload();
});
</script>
}
