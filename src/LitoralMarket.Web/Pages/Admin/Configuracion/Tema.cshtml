@page
@model LitoralMarket.Web.Pages.Admin.Configuracion.TemaModel
@{
    ViewData["Title"] = "Temas visuales";

    var temas = new[]
    {
        new { Id = "light",         Nombre = "Claro",          Desc = "Fondos claros, contraste suave, diseño limpio",                 Icono = "bi-sun",          Bg = "#F6FAF7", Nav = "#0D5C35", Btn = "#1DB062", Acento = "#94C9E9" },
        new { Id = "dark",          Nombre = "Oscuro",         Desc = "Fondos oscuros, menor fatiga visual, diseño moderno",           Icono = "bi-moon-stars",   Bg = "#111827", Nav = "#145738", Btn = "#2DD885", Acento = "#7BBDE8" },
        new { Id = "system",        Nombre = "Sistema",        Desc = "Se adapta automáticamente al modo claro/oscuro del dispositivo",Icono = "bi-display",      Bg = "#F6FAF7", Nav = "#0D5C35", Btn = "#1DB062", Acento = "#94C9E9" },
        new { Id = "high-contrast", Nombre = "Alto contraste", Desc = "Accesibilidad mejorada, contrastes fuertes, mejor legibilidad", Icono = "bi-eye",          Bg = "#ffffff", Nav = "#003800", Btn = "#008000", Acento = "#0070E0" },
        new { Id = "brand",         Nombre = "Dietética",      Desc = "Verde suave, beige, blanco cálido — estética natural",         Icono = "bi-leaf",         Bg = "#FAF7F2", Nav = "#355E4D", Btn = "#6BAE8E", Acento = "#A8C4B2" },
    };
}

<div class="container py-4" style="max-width:900px">

    <div class="d-flex align-items-center gap-2 mb-4">
        <i class="bi bi-palette2 fs-3 text-success"></i>
        <div>
            <h4 class="mb-0 fw-bold">Temas visuales</h4>
            <p class="text-muted mb-0 small">Seleccioná el tema predeterminado del panel de administración</p>
        </div>
    </div>

    @if (TempData["TemaAplicado"] is string temaAplicado)
    {
        <div class="alert alert-success d-flex align-items-center gap-2 mb-4" role="alert">
            <i class="bi bi-check-circle-fill"></i>
            Tema aplicado. Los visitantes con cookie guardada mantienen su preferencia individual.
        </div>
    }
    @if (TempData["ColoresGuardados"] is true)
    {
        <div class="alert alert-success d-flex align-items-center gap-2 mb-4" role="alert">
            <i class="bi bi-check-circle-fill"></i>
            Colores predominantes guardados. Se aplican a toda la tienda, sobre cualquier tema.
        </div>
    }
    @if (TempData["ColoresRestaurados"] is true)
    {
        <div class="alert alert-info d-flex align-items-center gap-2 mb-4" role="alert">
            <i class="bi bi-arrow-counterclockwise"></i>
            Colores restaurados. Cada tema vuelve a usar su paleta original.
        </div>
    }

    <!-- ═══ COLORES PREDOMINANTES ═══ -->
    <div class="card shadow-sm mb-4">
        <div class="card-body p-4">
            <div class="d-flex align-items-center gap-2 mb-1">
                <i class="bi bi-palette-fill text-success"></i>
                <span class="fw-bold">Colores predominantes</span>
                @if (Model.ColoresCustom)
                {
                    <span class="badge bg-success ms-2">Personalizados</span>
                }
                else
                {
                    <span class="badge bg-secondary ms-2">Por defecto</span>
                }
            </div>
            <p class="text-muted small mb-4">
                Elegí los 2 colores de marca. El <strong>primario</strong> tiñe navbar, menú y botones;
                el <strong>acento</strong> tiñe badges, precios y detalles. Se aplican globalmente
                <strong>sobre cualquier tema</strong> (claro, oscuro, etc.).
            </p>

            <form method="post" asp-page-handler="Colores" id="form-colores">
                <div class="row g-4 align-items-end">
                    <!-- Primario -->
                    <div class="col-12 col-md-4">
                        <label class="form-label small fw-semibold mb-1">Color primario</label>
                        <div class="input-group">
                            <input type="color" class="form-control form-control-color" name="primario"
                                   id="cp-primario" value="@Model.ColorPrimario"
                                   title="Color primario" style="max-width:52px" />
                            <input type="text" class="form-control text-uppercase" id="cp-primario-hex"
                                   value="@Model.ColorPrimario" maxlength="7" spellcheck="false"
                                   pattern="^#[0-9a-fA-F]{6}$" aria-label="Hex primario" />
                        </div>
                    </div>
                    <!-- Acento -->
                    <div class="col-12 col-md-4">
                        <label class="form-label small fw-semibold mb-1">Color de acento</label>
                        <div class="input-group">
                            <input type="color" class="form-control form-control-color" name="acento"
                                   id="cp-acento" value="@Model.ColorAcento"
                                   title="Color de acento" style="max-width:52px" />
                            <input type="text" class="form-control text-uppercase" id="cp-acento-hex"
                                   value="@Model.ColorAcento" maxlength="7" spellcheck="false"
                                   pattern="^#[0-9a-fA-F]{6}$" aria-label="Hex acento" />
                        </div>
                    </div>
                    <!-- Preview -->
                    <div class="col-12 col-md-4">
                        <label class="form-label small fw-semibold mb-1">Vista previa</label>
                        <div class="d-flex align-items-center gap-2" id="cp-preview">
                            <span class="badge px-3 py-2" id="cp-prev-primario"
                                  style="background:@Model.ColorPrimario">Primario</span>
                            <span class="badge px-3 py-2" id="cp-prev-acento"
                                  style="background:@Model.ColorAcento">Acento</span>
                        </div>
                    </div>
                </div>

                <div class="d-flex flex-wrap gap-2 mt-4">
                    <button type="submit" class="btn btn-success btn-sm">
                        <i class="bi bi-check-lg me-1"></i>Guardar colores
                    </button>
                    <button type="submit" class="btn btn-outline-secondary btn-sm"
                            asp-page-handler="RestaurarColores" formnovalidate>
                        <i class="bi bi-arrow-counterclockwise me-1"></i>Restaurar por defecto
                    </button>
                </div>
            </form>
        </div>
    </div>

    <h6 class="fw-bold text-muted mb-3">
        <i class="bi bi-brightness-high me-1"></i>Modo de visualización
    </h6>

    <div class="row g-3">
        @foreach (var t in temas)
        {
            var esActivo = Model.TemaActual == t.Id;
            <div class="col-12 col-sm-6 col-lg-4">
                <div class="card h-100 @(esActivo ? "border-success border-2" : "") shadow-sm">
                    <!-- Mini preview -->
                    <div style="height:80px; border-radius:8px 8px 0 0; overflow:hidden; position:relative; background:@t.Bg">
                        <div style="height:22px; background:@t.Nav; display:flex; align-items:center; padding:0 10px; gap:6px">
                            <span style="color:#fff; font-size:9px; font-weight:700; opacity:.9">🏪 @t.Nombre</span>
                            <div style="flex:1; background:rgba(255,255,255,0.2); border-radius:8px; height:8px;"></div>
                            <div style="width:14px; height:14px; border-radius:50%; background:@t.Btn; opacity:.9"></div>
                        </div>
                        <div style="padding:8px; display:flex; gap:6px; flex-wrap:wrap">
                            <div style="height:20px; background:@t.Btn; border-radius:6px; padding:0 8px; display:flex; align-items:center">
                                <span style="font-size:8px; font-weight:700; color:#fff">$850</span>
                            </div>
                            <div style="height:20px; background:@t.Acento; border-radius:6px; padding:0 8px; display:flex; align-items:center">
                                <span style="font-size:8px; font-weight:600; color:#fff">Acento</span>
                            </div>
                        </div>
                        @if (esActivo)
                        {
                            <div style="position:absolute; top:6px; right:6px; background:#198754; color:#fff; border-radius:50%; width:18px; height:18px; display:flex; align-items:center; justify-content:center; font-size:10px">
                                <i class="bi bi-check"></i>
                            </div>
                        }
                    </div>
                    <!-- Info -->
                    <div class="card-body p-3">
                        <div class="d-flex align-items-center gap-2 mb-1">
                            <i class="bi @t.Icono text-success"></i>
                            <span class="fw-semibold">@t.Nombre</span>
                            @if (esActivo)
                            {
                                <span class="badge bg-success ms-auto">Activo</span>
                            }
                        </div>
                        <p class="text-muted small mb-3" style="line-height:1.3">@t.Desc</p>
                        <form method="post" asp-page-handler="Aplicar">
                            <input type="hidden" name="tema" value="@t.Id" />
                            <button type="submit" class="btn @(esActivo ? "btn-outline-success" : "btn-outline-secondary") btn-sm w-100"
                                    onclick="LitoralTheme && LitoralTheme.set('@t.Id')">
                                @(esActivo ? "✓ Aplicado" : "Aplicar")
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="alert alert-light border mt-4 small d-flex gap-2 align-items-start">
        <i class="bi bi-info-circle text-primary mt-1 flex-shrink-0"></i>
        <div>
            <strong>Comportamiento:</strong> cada usuario puede cambiar su tema desde el menú
            <i class="bi bi-circle-half"></i> en el navbar. La selección se guarda en su navegador
            (cookie + localStorage). El botón "Aplicar" aquí cambia el tema del administrador
            en este dispositivo.
        </div>
    </div>

</div>

@section Scripts {
<script>
(function () {
    var HEX = /^#[0-9a-fA-F]{6}$/;

    function bind(colorId, hexId, prevId) {
        var color = document.getElementById(colorId);
        var hex   = document.getElementById(hexId);
        var prev  = document.getElementById(prevId);

        function toPrev(v) { if (prev) prev.style.background = v; }

        // picker → texto + preview
        color.addEventListener('input', function () {
            hex.value = color.value.toUpperCase();
            toPrev(color.value);
        });

        // texto → picker + preview (solo si es hex válido)
        hex.addEventListener('input', function () {
            var v = hex.value.trim();
            if (v[0] !== '#') { v = '#' + v; }
            if (HEX.test(v)) {
                color.value = v;
                toPrev(v);
                hex.classList.remove('is-invalid');
            } else {
                hex.classList.add('is-invalid');
            }
        });
    }

    bind('cp-primario', 'cp-primario-hex', 'cp-prev-primario');
    bind('cp-acento',   'cp-acento-hex',   'cp-prev-acento');
}());
</script>
}
