@page
@model MisPedidosModel
@using System.Globalization
@{
    ViewData["Title"] = "Mis Pedidos";
}

<h2 class="mb-1"><i class="bi bi-bag me-2"></i>Mis pedidos</h2>
<p class="text-muted small mb-4">Pedidos de los últimos 3 meses en estado pendiente o confirmado.</p>

@if (Model.EsAnonimo)
{
    <div class="alert alert-info d-flex align-items-start gap-2 mb-4">
        <i class="bi bi-info-circle-fill fs-5 flex-shrink-0 mt-1"></i>
        <div>
            Estás viendo los pedidos realizados desde <strong>este navegador</strong>.
            Si cambiás de dispositivo o borrás las cookies, no verás estos pedidos.
        </div>
    </div>
}

@if (!Model.Pedidos.Any())
{
    <div class="alert alert-secondary">
        <i class="bi bi-bag me-2"></i>
        No realizaste ningún pedido en los últimos 3 meses.
    </div>
}
else
{
    @foreach (var pedido in Model.Pedidos)
    {
        <div class="card mb-3 shadow-sm border-0">
            <div class="card-header d-flex flex-wrap align-items-center gap-2 bg-white border-bottom py-2">

                <strong class="me-auto">Pedido #@pedido.Id</strong>

                <span class="text-muted small">@pedido.Fecha.ToString("dd/MM/yyyy HH:mm")</span>

                @if (!Model.EsModoCredenciales)
                {
                    @if (pedido.Estado == "confirmado")
                    {
                        <span class="badge bg-success">Confirmado</span>
                    }
                    else if (pedido.Estado == "pendiente_pago")
                    {
                        <span class="badge bg-warning text-dark">Pendiente de pago</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">@pedido.Estado</span>
                    }
                }

                <span class="fw-bold" style="color:var(--verde);">$@pedido.Total.ToString("N2")</span>

                <a asp-page="/Pedido" asp-route-id="@pedido.Id"
                   class="btn btn-sm btn-outline-secondary">
                    <i class="bi bi-eye me-1"></i>Ver detalle
                </a>

            </div>
            <div class="card-body p-0">
                <table class="table table-sm mb-0">
                    <tbody>
                        @foreach (var item in pedido.Items)
                        {
                            <tr>
                                <td class="ps-3 small text-truncate" style="max-width:260px;">@item.Descripcion</td>
                                <td class="text-center small text-muted">×@item.Cantidad.ToString("G", CultureInfo.InvariantCulture)</td>
                                <td class="text-end pe-3 small fw-semibold">$@item.Subtotal.ToString("N2")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
}
