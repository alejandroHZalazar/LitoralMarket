@page
@model BuscarModel
@{
    ViewData["Title"] = $"Búsqueda: {Model.Termino}";
    ViewData["MostrarSinStock"] = Model.MostrarSinStock;
}

<h2 class="mb-1">Resultados para: <em>@Model.Termino</em></h2>
<p class="text-muted mb-4">@Model.TotalResultados resultado(s) encontrado(s)</p>

@if (!Model.Productos.Any())
{
    <div class="alert alert-info">No se encontraron productos con ese nombre.</div>
}
else
{
    <div class="row row-cols-2 row-cols-md-3 row-cols-lg-4 g-3">
        @foreach (var producto in Model.Productos)
        {
            <div class="col position-relative">
                <partial name="_ProductoCard" model="producto" />
            </div>
        }
    </div>

    @if (Model.TotalPaginas > 1)
    {
        int _ventana = 2;
        int _ini = Math.Max(1, Model.PaginaActual - _ventana);
        int _fin = Math.Min(Model.TotalPaginas, Model.PaginaActual + _ventana);

        <nav class="mt-4" aria-label="Paginación">
            <ul class="pagination justify-content-center flex-wrap">

                @* ← Anterior *@
                <li class="page-item @(Model.PaginaActual == 1 ? "disabled" : "")">
                    <a class="page-link" asp-page="/Buscar"
                       asp-route-q="@Model.Termino"
                       asp-route-pagina="@(Model.PaginaActual - 1)">
                        <i class="bi bi-chevron-left"></i>
                    </a>
                </li>

                @* Primera página + ellipsis *@
                @if (_ini > 1)
                {
                    <li class="page-item">
                        <a class="page-link" asp-page="/Buscar"
                           asp-route-q="@Model.Termino" asp-route-pagina="1">1</a>
                    </li>
                    @if (_ini > 2)
                    {
                        <li class="page-item disabled"><span class="page-link">…</span></li>
                    }
                }

                @* Ventana alrededor del actual *@
                @for (int i = _ini; i <= _fin; i++)
                {
                    <li class="page-item @(i == Model.PaginaActual ? "active" : "")">
                        <a class="page-link" asp-page="/Buscar"
                           asp-route-q="@Model.Termino" asp-route-pagina="@i">@i</a>
                    </li>
                }

                @* Ellipsis + última página *@
                @if (_fin < Model.TotalPaginas)
                {
                    @if (_fin < Model.TotalPaginas - 1)
                    {
                        <li class="page-item disabled"><span class="page-link">…</span></li>
                    }
                    <li class="page-item">
                        <a class="page-link" asp-page="/Buscar"
                           asp-route-q="@Model.Termino"
                           asp-route-pagina="@Model.TotalPaginas">@Model.TotalPaginas</a>
                    </li>
                }

                @* Siguiente → *@
                <li class="page-item @(Model.PaginaActual == Model.TotalPaginas ? "disabled" : "")">
                    <a class="page-link" asp-page="/Buscar"
                       asp-route-q="@Model.Termino"
                       asp-route-pagina="@(Model.PaginaActual + 1)">
                        <i class="bi bi-chevron-right"></i>
                    </a>
                </li>
            </ul>
        </nav>
    }
}
