@inject LitoralMarket.Application.Interfaces.IParametrosService Parametros
@inject LitoralMarket.Application.Interfaces.IProductoRepository ProductoRepo
@inject LitoralMarket.Application.Interfaces.ICarritoService CarritoSvc
@{
    var titulo       = await Parametros.GetTituloEcommerceAsync();
    var empresa      = await Parametros.GetNombreEmpresaAsync() ?? titulo;
    var rubros       = await ProductoRepo.ObtenerRubrosAsync();
    var estaLogueado = User.Identity?.IsAuthenticated ?? false;
    var modoAcceso   = await Parametros.GetModoAccesoAsync();
    var paginaActual = Context.Request.Path.Value ?? "/";
    var tienelogo    = (await Parametros.GetLogoAsync()) is { Length: > 0 };

    // Conteo real del carrito desde el servicio — funciona en cualquier página
    var pedidoId    = Context.Session.GetInt32("PedidoId");
    var cantCarrito = pedidoId.HasValue
        ? await CarritoSvc.ContarItemsAsync(pedidoId.Value)
        : 0;

    // Tema visual — leer cookie para evitar FOUC en el primer render
    var _temasValidos = new[]{"light","dark","system","high-contrast"};
    var _temaRaw      = Context.Request.Cookies["lm_theme"] ?? "light";
    var _tema         = Array.IndexOf(_temasValidos, _temaRaw) >= 0 ? _temaRaw : "light";

    // Colores predominantes (marca) — configurados por el admin, globales.
    // Se validan como hex #RRGGBB para evitar inyección en el <style>.
    static bool _esHex(string? c) => c is not null &&
        System.Text.RegularExpressions.Regex.IsMatch(c, "^#[0-9a-fA-F]{6}$");

    // Luminancia relativa WCAG y color de texto con mejor contraste (negro o blanco)
    // para un fondo dado. Así, sea cual sea el acento que elija el admin, el texto
    // que se dibuja encima (botones "Mis pedidos"/"ADMIN", badges, etc.) siempre
    // queda legible — en vez de asumir que el acento va a ser claro.
    static double _luminancia(string hex)
    {
        double canal(int v) { var c = v / 255.0; return c <= 0.03928 ? c / 12.92 : Math.Pow((c + 0.055) / 1.055, 2.4); }
        int r = Convert.ToInt32(hex.Substring(1, 2), 16);
        int g = Convert.ToInt32(hex.Substring(3, 2), 16);
        int b = Convert.ToInt32(hex.Substring(5, 2), 16);
        return 0.2126 * canal(r) + 0.7152 * canal(g) + 0.0722 * canal(b);
    }
    static double _contraste(double l1, double l2)
    {
        var claro = Math.Max(l1, l2); var oscuro = Math.Min(l1, l2);
        return (claro + 0.05) / (oscuro + 0.05);
    }
    static string _textoContrastante(string hexFondo)
    {
        var l = _luminancia(hexFondo);
        return _contraste(l, 0) >= _contraste(l, 1) ? "#12201A" : "#FFFFFF";
    }

    var _cpRaw = await Parametros.GetColorPrimarioAsync();
    var _caRaw = await Parametros.GetColorAcentoAsync();
    var _colorPrimario = _esHex(_cpRaw) ? _cpRaw : null;
    var _colorAcento   = _esHex(_caRaw) ? _caRaw : null;
    var _acentoTexto   = _colorAcento is not null ? _textoContrastante(_colorAcento) : null;
}
<!DOCTYPE html>
<html lang="es"@(_tema != "system" ? $" data-theme=\"{_tema}\"" : "")>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] != null ? $"{ViewData["Title"]} — {titulo}" : titulo)</title>
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <link rel="dns-prefetch" href="https://cdn.jsdelivr.net" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @if (_colorPrimario is not null || _colorAcento is not null)
    {
        <style>
        /* Colores predominantes definidos por el admin — se aplican sobre cualquier tema.
           Los tonos derivados se calculan con color-mix() a partir de los 2 colores base. */
        :root, :root[data-theme], :root:not([data-theme]) {
        @if (_colorPrimario is not null)
        {
            @:--verde:          @_colorPrimario !important;
            @:--verde-hover:    color-mix(in srgb, @_colorPrimario 90%, black) !important;
            @:--verde-oscuro:   color-mix(in srgb, @_colorPrimario 80%, black) !important;
            @:--verde-profundo: color-mix(in srgb, @_colorPrimario 60%, black) !important;
        }
        @if (_colorAcento is not null)
        {
            @:--dorado:         @_colorAcento !important;
            @:--dorado-claro:   color-mix(in srgb, @_colorAcento 62%, white) !important;
            @:--dorado-suave:   color-mix(in srgb, @_colorAcento 18%, transparent) !important;
            @:--celeste:        @_colorAcento !important;
            @:--celeste-oscuro: color-mix(in srgb, @_colorAcento 80%, black) !important;
            @:--celeste-suave:  color-mix(in srgb, @_colorAcento 18%, transparent) !important;
            @:--acento-texto:   @_acentoTexto !important;
        }
        }
        </style>
    }
    <script>/* Anti-FOUC: sincroniza tema desde localStorage antes del primer render */
    (function(){var t=localStorage.getItem('lm_theme'),v=['light','dark','system','high-contrast'];if(t&&v.indexOf(t)!==-1){if(t==='system')document.documentElement.removeAttribute('data-theme');else document.documentElement.setAttribute('data-theme',t);}})();
    </script>
</head>
<body>

<!-- Franja degradada decorativa -->
<div class="topbar"></div>

<!-- ===== NAVBAR estilo Amazon / Mercado Libre ===== -->
<nav class="navbar-lm">

    <!-- =========== FILA 1: BRAND + BUSCADOR + ACCIONES =========== -->
    <div class="navbar-main">
        <div class="container">
            <div class="navbar-main-grid">

                <!-- Brand -->
                <a class="navbar-brand" asp-page="/Index">
                    @if (tienelogo)
                    {
                        <img src="/logo" class="brand-logo" alt="@empresa" />
                    }
                    else
                    {
                        <span class="brand-icon"><i class="bi bi-tree-fill"></i></span>
                    }
                    <span class="brand-text">@empresa</span>
                </a>

                <!-- Buscador -->
                <form class="search-form" asp-page="/Buscar" method="get" role="search">
                    <input class="form-control" type="search" name="q"
                           placeholder="Buscar productos..."
                           value="@Context.Request.Query["q"]"
                           aria-label="Buscar" />
                    <button class="btn btn-buscar" type="submit" aria-label="Buscar">
                        <i class="bi bi-search"></i>
                    </button>
                </form>

                <!-- Acciones (carrito, mis pedidos, admin) -->
                <div class="navbar-actions">

                    <!-- Switcher de tema -->
                    <div class="dropdown">
                        <button class="btn-tema dropdown-toggle" type="button"
                                data-bs-toggle="dropdown" aria-expanded="false"
                                aria-label="Cambiar tema visual" title="Cambiar tema">
                            <i class="bi bi-circle-half" id="lm-theme-icon"></i>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end" style="min-width:190px">
                            <li><span class="dropdown-item-text small text-muted fw-semibold">
                                <i class="bi bi-palette me-1"></i>Tema visual
                            </span></li>
                            <li><button class="dropdown-item" data-lm-theme-btn="light" aria-pressed="false">
                                <i class="bi bi-sun me-2"></i>Claro
                            </button></li>
                            <li><button class="dropdown-item" data-lm-theme-btn="dark" aria-pressed="false">
                                <i class="bi bi-moon-stars me-2"></i>Oscuro
                            </button></li>
                            <li><button class="dropdown-item" data-lm-theme-btn="system" aria-pressed="false">
                                <i class="bi bi-display me-2"></i>Sistema
                            </button></li>
                            <li><button class="dropdown-item" data-lm-theme-btn="high-contrast" aria-pressed="false">
                                <i class="bi bi-eye me-2"></i>Alto contraste
                            </button></li>
                        </ul>
                    </div>

                    <a asp-page="/Carrito" class="btn-carrito" aria-label="Ver carrito" data-no-prefetch>
                        <i class="bi bi-cart3"></i>
                        <span class="action-label">Carrito</span>
                        @if (cantCarrito > 0)
                        {
                            <span class="badge-carrito">@cantCarrito</span>
                        }
                    </a>

                    @if (modoAcceso == "credenciales")
                    {
                        @if (estaLogueado)
                        {
                            <div class="dropdown">
                                <button class="btn-login dropdown-toggle" type="button"
                                        data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-person-circle"></i>
                                    <span class="action-label">@User.FindFirst("nombre")?.Value</span>
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li><a class="dropdown-item" asp-page="/MisPedidos"><i class="bi bi-bag me-2 text-muted"></i>Mis pedidos</a></li>
                                    @if (User.IsInRole("admin"))
                                    {
                                        <li><hr class="dropdown-divider"></li>
                                        <partial name="_AdminMenuItems" />
                                    }
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form asp-page="/Logout" method="post">
                                            <button class="dropdown-item text-danger" type="submit">
                                                <i class="bi bi-box-arrow-right me-2"></i>Cerrar sesión
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </div>
                        }
                        else
                        {
                            <a class="btn-login" asp-page="/MisPedidos">
                                <i class="bi bi-bag"></i>
                                <span class="action-label">Mis pedidos</span>
                            </a>
                            <a class="btn-login" asp-page="/Login">
                                <i class="bi bi-box-arrow-in-right"></i>
                                <span class="action-label">Ingresar</span>
                            </a>
                        }
                    }
                    else
                    {
                        <a class="btn-login" asp-page="/MisPedidos">
                            <i class="bi bi-bag"></i>
                            <span class="action-label">Mis pedidos</span>
                        </a>

                        @if (estaLogueado && (User.IsInRole("admin") || User.FindFirst("esAdmin")?.Value == "true"))
                        {
                            <div class="dropdown">
                                <button class="btn-login dropdown-toggle" type="button"
                                        data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-shield-lock-fill text-success"></i>
                                    <span class="action-label">@User.FindFirst("nombre")?.Value</span>
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <partial name="_AdminMenuItems" />
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form asp-page="/Logout" method="post">
                                            <button class="dropdown-item text-danger" type="submit">
                                                <i class="bi bi-box-arrow-right me-2"></i>Cerrar sesión
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </div>
                        }
                        else if (!estaLogueado)
                        {
                            <a class="btn-admin-acceso" asp-page="/Login" title="Acceso administrador">
                                <i class="bi bi-shield-lock"></i>
                            </a>
                        }
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- =========== FILA 2: MENÚ DE RUBROS =========== -->
    <div class="navbar-rubros">
        <div class="container d-flex align-items-center">

            <button class="rubros-toggler d-lg-none" type="button"
                    data-bs-toggle="collapse" data-bs-target="#rubrosCollapse"
                    aria-controls="rubrosCollapse" aria-expanded="false">
                <i class="bi bi-list me-1"></i>Categorías
            </button>

            <div class="collapse d-lg-block rubros-collapse" id="rubrosCollapse">
                <ul class="rubros-list">
                    <li>
                        <a class="rubro-link @(paginaActual == "/" ? "active" : "")" asp-page="/Index">
                            <i class="bi bi-house-fill me-1"></i>Inicio
                        </a>
                    </li>
                    @foreach (var rubro in rubros)
                    {
                        var rubroActivo = paginaActual.StartsWith("/catalogo", StringComparison.OrdinalIgnoreCase)
                                          && Context.Request.RouteValues["rubroId"]?.ToString() == rubro.Id.ToString();
                        <li>
                            <a class="rubro-link @(rubroActivo ? "active" : "")"
                               asp-page="/Catalogo" asp-route-rubroId="@rubro.Id">
                                @rubro.Descripcion
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </div>
</nav>

<!-- ===== CONTENIDO ===== -->
<main class="container py-4">
    @if (TempData["Mensaje"] is string msg)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>@msg
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @RenderBody()
</main>

<!-- ===== FOOTER estilo compacto ===== -->
<footer class="footer-lm">

    <!-- Banda principal: brand | nav inline | dev -->
    <div class="footer-main">
        <div class="container">
            <div class="footer-grid">

                <!-- Brand mini -->
                <div class="footer-brand-mini">
                    @if (tienelogo)
                    {
                        <img src="/logo" class="footer-logo" alt="@empresa" />
                    }
                    <div>
                        <div class="footer-empresa-nombre">@empresa</div>
                        <div class="footer-empresa-sub">Chaco, Argentina</div>
                    </div>
                </div>

                <!-- Links rápidos inline -->
                <nav class="footer-nav" aria-label="Enlaces de navegación">
                    <a asp-page="/Index">Inicio</a>
                    @foreach (var rubro in rubros.Take(5))
                    {
                        <a asp-page="/Catalogo" asp-route-rubroId="@rubro.Id">@rubro.Descripcion</a>
                    }
                </nav>

                <!-- Dev compacto -->
                <div class="footer-dev-compact">
                    <span class="footer-dev-text">Por <strong>LitoralSys</strong></span>
                    <button type="button" class="btn-acerca-de"
                            data-bs-toggle="modal" data-bs-target="#modalAcercaDe"
                            aria-label="Acerca de LitoralSys">
                        <i class="bi bi-info-circle"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Banda inferior delgada (igual estilo que franja de rubros) -->
    <div class="footer-bottom-strip">
        <div class="container d-flex justify-content-between align-items-center flex-wrap gap-2">
            <span>&copy; @DateTime.Now.Year <strong>@empresa</strong> &mdash; Todos los derechos reservados</span>
            <span>Powered by <a href="https://web.facebook.com/LitoralSys/" target="_blank" rel="noopener">LitoralSys</a></span>
        </div>
    </div>
</footer>

<!-- ===== MODAL ACERCA DE LITORALSYS ===== -->
<div class="modal fade" id="modalAcercaDe" tabindex="-1"
     aria-labelledby="modalAcercaDeLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content modal-acerca-de">

            <div class="modal-header border-0 pb-0">
                <button type="button" class="btn-close btn-close-white"
                        data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>

            <div class="modal-body text-center px-4 pb-2">
                <!-- Logo LitoralSys -->
                <div class="modal-dev-logo-wrap mb-3">
                    <img src="/images/litoralsys-logo.png"
                         alt="LitoralSys"
                         class="modal-dev-logo"
                         onerror="this.style.display='none'" />
                </div>

                <h5 class="modal-dev-title" id="modalAcercaDeLabel">LitoralSys</h5>
                <p class="modal-dev-subtitle">Desarrollo de Software</p>

                <hr class="modal-divider" />

                <p class="modal-dev-desc">
                    <strong>LitoralSys</strong> es una empresa de desarrollo de software con sede en el
                    Chaco, Argentina, especializada en soluciones tecnológicas a medida para comercios,
                    distribuidoras y empresas de la región del Litoral. Diseñamos sistemas de gestión,
                    plataformas de e-commerce y aplicaciones que impulsan la transformación digital de
                    los negocios locales.
                </p>

                <!-- Redes sociales -->
                <div class="modal-redes">
                    <a href="https://web.facebook.com/LitoralSys/"
                       target="_blank" rel="noopener"
                       class="btn-red-social btn-facebook"
                       aria-label="Facebook">
                        <i class="bi bi-facebook"></i>
                        <span>Facebook</span>
                    </a>
                    <a href="https://www.instagram.com/litoralsys/"
                       target="_blank" rel="noopener"
                       class="btn-red-social btn-instagram"
                       aria-label="Instagram">
                        <i class="bi bi-instagram"></i>
                        <span>Instagram</span>
                    </a>
                    <a href="https://www.tiktok.com/@@litoralsys"
                       target="_blank" rel="noopener"
                       class="btn-red-social btn-tiktok"
                       aria-label="TikTok">
                        <i class="bi bi-tiktok"></i>
                        <span>TikTok</span>
                    </a>
                </div>
            </div>

            <div class="modal-footer border-0 justify-content-center pt-1 pb-3">
                <small class="text-muted">© @DateTime.Now.Year LitoralSys — Todos los derechos reservados</small>
            </div>
        </div>
    </div>
</div>

<!-- Toast carrito -->
<div class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index:1100">
    <div id="toastCarrito" class="toast align-items-center border-0" role="alert" aria-live="assertive" aria-atomic="true">
        <div class="d-flex">
            <div class="toast-body d-flex align-items-center gap-2">
                <i class="bi bi-cart-check-fill fs-5 text-success"></i>
                <span id="toastMensaje">Producto agregado al carrito</span>
            </div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Cerrar"></button>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
<script src="~/js/tema.js" asp-append-version="true"></script>
<script src="~/js/prefetch.js" asp-append-version="true" defer></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
